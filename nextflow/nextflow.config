// ---------------------------------------------------------------------------------- //
//                             Nextflow / executor settings
// ---------------------------------------------------------------------------------- //
conda.enabled = true

profiles {
    local {
        process.executor = 'local'
    }
    lsf {
        process {
            executor = 'lsf'
            errorStrategy = { task.attempt <= 3 ? "retry" : "finish" }
        }

        executor {
            name = 'lsf'
            perJobMemLimit = true
            poolSize = 4
            submitRateLimit = '5 sec'
            killBatchSize = 50
            queueSize=50
        }

        params {
            max_memory = 250.GB
            max_cpus = 64
            max_time = 12.h
            withLabel:process_long {
                max_time = 48.h
            }
        }
    }
}

// ---------------------------------------------------------------------------------- //
//                                  Process requirements
// ---------------------------------------------------------------------------------- //

process {
    withLabel: tiny_img {
        cpus = 1
        memory = 4.GB
        queue = 'imaging'
        time = "1h"
    }
    
    withLabel: small_img {
        cpus = 1
        memory = 6.GB
        queue = 'imaging'
        time = "1h"
    }

    withLabel: tiny {
        cpus = 1
        memory = 1.GB
        queue = 'normal'
        time = "1h"
    }
    
    withLabel: normal {
        cpus = 1
        memory = { 16.GB * task.attempt }
        queue = 'normal'
        time =  { 2.hour * task.attempt }
    }
    
    withLabel: himem {
        cpus = 1
        memory = { 64.GB * task.attempt }
        queue = 'normal'
        time = "12h"
    }
    
    
    //alias interj_gpu="bsub -n1 -q gpu-normal -G teamtrynka -M4000 -gpu - -R'span[hosts=1] select[mem>4000] rusage[mem=4000]' -Is bash"
    
    //bsub -n1 -q gpu-normal -G teamtrynka -M4000 -gpu - -R'span[hosts=1] rusage[mem=4000] select[mem>4000 && gmem>500]' -gpu "num=1" -Is bash
    withLabel: gpu_midmem {
        cpus = 1
        memory =  { 64.GB * task.attempt }
        queue = 'gpu-normal'
        time = { 1.hour * task.attempt }
        clusterOptions = '-gpu \"num=1:mode=exclusive_process\"'
    }
}

// ---------------------------------------------------------------------------------- //
//                                  parameters
// ---------------------------------------------------------------------------------- //

params {

    // ---------------------------------------------------------------------------------- //
    //                          Run specific parameters
    // ---------------------------------------------------------------------------------- //
    // Core manifest
    // plate	index_xml	channels	bp_channels	cp_nucl_channel	cp_cell_channel
    // set bp_channels to none to not run basicpy
    // set cp_cell_channel to none to not run cellpose
    // set cp_nucl_channel to none to run cellpose without a nucleus channel
    // If a registration manifest is provided, only reference plates will be run through cellpose
    //rn_manifest="/software/teamtrynka/installs/tglow-core/testing/maniffest_bodipy_test.tsv"
    rn_manifest=null
    
    // Well level manifest (blacklist)
    // Path to a file with columns <plate> <well>
    // Specifying which wells to ignore. This is usefull to deal with edgecases in a plate
    // Leave at null to ingore.
    rn_blacklist=null

    // Well level manifest (whitelist)
    // This is a file with <well> <plate> <pe xml> structure indicating which wells on which plates to run
    // Set to null if auto generated from perking elmer XML
    // If not null, supply a list ['/path/to/plate1_manifest.csv', '/path/to/plate2_manifest.csv', ...]
    rn_manifest_well=null
    //plate_index_xml="/nfs/t217_imaging/HarmonyExports/jm52_20230721_Bodipy-OleicAcid_Confocal__2023-07-21T17_40_59-Measurement\ 1/Images/Index.idx.xml"
    
    // Registration manifest
    // This dicates which plates will be merged and registered. If left to null
    // no merging or registration is performed
    rn_manifest_registration=null

    // Results / publish dir
    //rn_publish_dir="/lustre/scratch125/humgen/projects/cell_activation_tc/projects/pipeline_dev/cellpose_test/bodipy_test"
    rn_publish_dir=null

    // Permanent cache for images
    //rn_image_dir="${rn_publish_dir}/images"
    rn_image_dir=null
    
    // Max project prior to running segmentation and cellprofiler
    rn_max_project=false

    // Only run 3 wells 
    rn_testmode=false
    
    // ---------------------------------------------------------------------------------- //
    //                                      Basicpy
    // ---------------------------------------------------------------------------------- //
    // Channels to fit basicpy models on, leave null to run all channels specified in manifest
    // in manifest to not run basicpy for a plate, set channels to "none"
    // otherwise specify [[<plate>, <channel>], [<plate>, <channel>], [<plate>, <channel>]]
    // to override manifest
    bp_channels=null
    
    // Do not tune basicpy model
    // [NOT RECCOMENDED] but usefull for testing
    bp_no_tune=false
    
    // Number of random images to train on.
    // Sampled with replacement.
    // If --merge_n is specified this is the number  of images that are max projected into one.
    // so bp_nimg=100 & bp_merge_n=20 would train basicpy on 20 newly generated images each 
    // consisting of the max projection of 100 randomly selected images from the plate
    bp_nimg=100
    
    // Number of times to max project random selection --nimg number of images. 
    // If > 1 basicpy is run on this number of max projected images.
    // Set to null to run vanilla basicpy with no merging
    // This is usefull if your images are low density and the flatfields tend to be
    // the background signal rather then the foreground signal.
    // bp_nimg=100 and bp_merge_n=50 is a reasonable starting point, but milage may vary!!!
    bp_merge_n=null
    
    // Instead of randomly picking one plane for a stack, use all planes.
    // This can give issues with basicpy as it does not like correlations too much and
    // assumes random variation between images.
    // [NOT RECCOMENDED]
    bp_all_planes=false
    
    // ---------------------------------------------------------------------------------- //
    //                                      Cellpose
    // ---------------------------------------------------------------------------------- //
    // Estimated cellsize for cellpose in pixels.
    // Set this to something resonable, these are estimates for T cells
    cp_cell_size=60
    
    // Estimated nucleus size for cellpose in pixels
    // Set this to something resonable, these are estimates for T cells
    cp_nucl_size=50
    
    // Cellpose model
    // The util was built on the cyto2 model and if possible will use a nucleus channel.
    // As such I can't confirm other models work, but in princple they should.
    cp_model="cyto2"
    
    // Cellpose min cell area in pixels
    // This the minimal area of the ROIs.
    // If null defaults to 2π (1/6th of cp_cell_size) for 2d
    // If null defaults to 4π (1/6th of cp_cell_size)^2 for 3d
    cp_min_cell_area=null
    
    // Cellpose min nucl area in pixels
    // This the minimal area of the ROIs.
    // If null defaults to 2π (1/6th of cp_nucl_size) for 2d
    // If null defaults to 4π (1/6th of cp_nucl_size)^2 for 3d
    cp_min_nucl_area=null
    
    // ---------------------------------------------------------------------------------- //
    //                                      Registration
    // ---------------------------------------------------------------------------------- //
    // IF registration manifest is provided
    
    // Make images of the registration results
    rg_plot=true
    
    // Evaluate registration results pearson correlation between registration channels
    rg_eval=true
    
    // ---------------------------------------------------------------------------------- //
    //                                      Tglow
    // ---------------------------------------------------------------------------------- //
    // Tglow conda env
    tg_conda_env = "/software/teamtrynka/installs/tglow"

    // Dir to find tglow scripts
    tg_core_dir="/software/teamtrynka/installs/tglow-core/core/runners"
    
    // ---------------------------------------------------------------------------------- //
    //                                  Cellprofiler
    // ---------------------------------------------------------------------------------- //
    // Execute  cellprofiler
    cpr_run=true
    
    // cellprofiler pipeline for max projections
    cpr_pipeline_2d=null
    
    // cellprofiler pipeline for 3d
    cpr_pipeline_3d=null
    
    // cellprofiler plugins
    cpr_plugins="/software/teamtrynka/installs/cellprofiler/plugins"
    
    // cellprofiler conda env
    cpr_conda_env='/software/teamtrynka/installs/cellprofiler'
}
