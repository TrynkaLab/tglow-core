conda.enabled = true


params {

    // Tglow conda env
    conda_env = "/software/teamtrynka/installs/tglow"

    tglow_core_dir="/software/teamtrynka/installs/tglow-core/core/"
    tglow_image_dir="/software/teamtrynka/installs/tglow-core/testing/test_output/nextflow/images"


    // TODO: now pipeline is per plate
    // Core manifest
    // <plate> <pe xml>
    manifest="/software/teamtrynka/installs/tglow-core/testing/maniffest_bodipy_test.tsv"

    // Plate level manifest
    // This is a file with <well> <plate> <pe xml> structure indicating which wells on which plates to run
    // Set to null if auto generated from perking elmer XML
    // If not null, supply a list ['/path/to/plate1_manifest.csv', '/path/to/plate2_manifest.csv', ...]
    plate_manifest=null
    //plate_index_xml="/nfs/t217_imaging/HarmonyExports/jm52_20230721_Bodipy-OleicAcid_Confocal__2023-07-21T17_40_59-Measurement\ 1/Images/Index.idx.xml"
    
}
